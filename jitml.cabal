    hs-source-dirs:   src gen
    default-language: GHC2024
    ghc-options:      -Wall -Wcompat
    build-depends:
        base >=4.21 && <4.22,
        text,
        async,
        bytestring,
        aeson,
        base64-bytestring,
        containers,
        cryptohash-sha1,
        cryptohash-sha256,
        proto-lens,
        proto-lens-runtime,
        dhall,
        directory,
        filepath,
        mtl,
        network,
        optparse-applicative,
        prettyprinter,
        prettyprinter-ansi-terminal,
        ansi-terminal,
        path,
        path-io,
        random,
        serialise,
        stm,
        typed-process,
        safe-exceptions,
        tasty,
        tasty-hunit,
        tasty-quickcheck,
        tasty-golden,
        temporary,
        time,
        unix,
        vector,
        zlib

    if flag(cuda)
        cpp-options:     -DJITML_CUDA_BINDINGS=1
        extra-libraries:
            cudart
            cublas
            cudnn

        extra-lib-dirs:  /usr/local/cuda/lib64

executable jitml
    main-is:          Main.hs
    hs-source-dirs:   app
    default-language: GHC2024
    ghc-options:      -Wall -Wcompat
    build-depends:
        base >=4.21 && <4.22,
        jitml

executable jitml-demo
    main-is:          Demo.hs
    hs-source-dirs:   app
    default-language: GHC2024
    ghc-options:      -Wall -Wcompat
    build-depends:
        base >=4.21 && <4.22,
        jitml

