cabal-version: 3.16
name:          jitml
version:       0.1.0.0
license:       MIT
license-file:  LICENSE
maintainer:    maintainers@example.invalid
author:        jitML contributors
tested-with:   ghc ==9.12.4
synopsis:
    Deterministic, reproducible, JIT-compiled machine learning for Haskell

description:
    jitML is a Haskell-native machine learning framework with a doctrine-shaped CLI.

build-type:    Simple

flag cuda
    description:
        Compile against the host CUDA toolkit so the typed cuBLAS/cuDNN
        bindings under `JitML.Engines.CublasBindings` /
        `JitML.Engines.CudnnBindings` link against `libcublas` and
        `libcudnn`. Used by `jitml:local` and any Linux CUDA validation
        host. Off by default so the warning-clean baseline build still
        succeeds on hosts without `nvcc`, `libcublas-dev`, or
        `libcudnn-dev` installed.

    default:     False
    manual:      True

